# Example env for the license audit tool. Copy relevant lines into your shell
# (or a private .env that is gitignored). No values are committed to the repo.
#
# gemma — local vLLM (no key needed). Start the service first:
#   cd ~/Projects/gwmm && docker compose up -d   (maps 127.0.0.1:8000)
export AUDIT_GEMMA_URL="http://localhost:8000/v1"
export AUDIT_GEMMA_MODEL="RedHatAI/gemma-4-12B-it-FP8-Dynamic"

# glm5.2 — Volcano Engine Ark, coding endpoint (no endpoint-id needed).
# Direct connect to the official Ark API; the audit tool does NOT route through
# the 4005 Opus/litellm proxy (that proxy is Claude-Code-specific). The code
# appends "/chat/completions" to AUDIT_GLM_URL, so the base must include /v3.
# Key: ARK_API_KEY_HO (= 1Password HOLLY_ARK_API_KEY). Load via op-secrets,
# never hardcode. Example:  export ARK_API_KEY_HO="$(op read ...)"
export AUDIT_GLM_URL="https://ark.cn-beijing.volces.com/api/coding/v3"
export AUDIT_GLM_MODEL="glm-5.2"
# export ARK_API_KEY_HO="..."   # load from 1Password, do not commit
